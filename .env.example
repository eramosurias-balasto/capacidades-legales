# Variables de entorno (SPEC §8). Copiar a .env.local para desarrollo y configurar en
# Railway para producción. NUNCA versionar el .env con valores reales.

# Supabase — solo la base de datos Postgres.
SUPABASE_URL=
# service_role_key: ignora RLS. SOLO en el servidor. Jamás prefijar con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Dashboard protegido por contraseña única.
DASHBOARD_PASSWORD=
# Secreto para firmar la cookie de sesión del dashboard (usar una cadena larga y aleatoria).
SESSION_SECRET=

# URL pública de la app (Railway). Ej. https://<app>.up.railway.app
NEXT_PUBLIC_APP_URL=
