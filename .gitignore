# dependencias
node_modules/
.pnp
.pnp.js

# next.js
.next/
out/
build/
next-env.d.ts.bak
*.tsbuildinfo

# producción
dist/

# entorno y secretos
.env
.env*.local
.env.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# testing / cobertura
coverage/

# sistema operativo
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/

# análisis en R
analisis-r/*.html
analisis-r/*_files/
# salidas de render_seguro.R (knit intermedio por escala); la plantilla es .qmd, no .md
analisis-r/analisis_rasch_*.md
# figuras que knitr genera al render (artefacto, se regenera)
analisis-r/figure/
.Rproj.user/
.Rhistory
.RData
# easyRasch se versiona como fuente (GPL-3) para reproducibilidad, pero NO su sitio
# renderizado (pkgdown) ni artefactos pesados: no hacen falta para pkgload::load_all().
analisis-r/easyRasch-main/docs/

# datos exportados (no versionar respuestas reales)
*.csv
# excepción: los datos sintéticos de prueba del análisis R sí se versionan
!analisis-r/datos_prueba/*.csv
