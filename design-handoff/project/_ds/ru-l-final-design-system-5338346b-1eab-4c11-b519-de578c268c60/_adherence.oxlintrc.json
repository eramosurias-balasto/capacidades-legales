{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/instrument/**",
              "ui_kits/audit/**",
              "ui_kits/matter-portal/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Switzer|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Switzer, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|shape|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, shape."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|success|warning|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'success' | 'warning' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tint|outline|solid)$/]",
        "message": "<Badge> variant must be one of 'tint' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|square)$/]",
        "message": "<Badge> shape must be one of 'pill' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|fullWidth|pill|leadingIcon|trailingIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, fullWidth, pill, leadingIcon, trailingIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocumentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|reference|kind|meta|updated|status|accent|onClick|key|ref|className|style|children)$/]",
        "message": "<DocumentCard> doesn't accept that prop. Declared props: title, reference, kind, meta, updated, status, accent, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|action|align|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: eyebrow, title, description, action, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<EmptyState> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|mono|hint|error|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, mono, hint, error, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatterStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|lang|label|variant|key|ref|className|style|children)$/]",
        "message": "<MatterStatus> doesn't accept that prop. Declared props: stage, lang, label, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatterStatus'] > JSXAttribute[name.name='stage'] > Literal[value!=/^(?:drafting|review|delivered|hold)$/]",
        "message": "<MatterStatus> stage must be one of 'drafting' | 'review' | 'delivered' | 'hold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatterStatus'] > JSXAttribute[name.name='lang'] > Literal[value!=/^(?:es|en)$/]",
        "message": "<MatterStatus> lang must be one of 'es' | 'en'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MatterStatus'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:capsule|inline)$/]",
        "message": "<MatterStatus> variant must be one of 'capsule' | 'inline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreDial'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|max|label|size|stroke|flat|halo|animate|key|ref|className|style|children)$/]",
        "message": "<ScoreDial> doesn't accept that prop. Declared props: score, max, label, size, stroke, flat, halo, animate."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|mono|width|render|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: key, header, align, mono, width, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToastAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|key|ref|className|style|children)$/]",
        "message": "<ToastAction> doesn't accept that prop. Declared props: label, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
